{
  "name": "insight",
  "version": "1.0.0",
  "main": "./dist-electron/main.js",
  "scripts": {
    "clean": "rimraf dist dist-electron",
    "dev": "vite",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "npm run typecheck",
    "verify": "npm run clean && npm run typecheck && npm run build && npm run build:electron && npm run app:build",
    "build": "npm run clean && tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "postinstall": "cross-env SHARP_IGNORE_GLOBAL_LIBVIPS=1 npm rebuild sharp",
    "electron:dev": "npm run build:electron && copy electron\\wasapi-loopback.exe dist-electron\\wasapi-loopback.exe >nul 2>&1 & cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build:electron && copy electron\\wasapi-loopback.exe dist-electron\\wasapi-loopback.exe >nul 2>&1 & cross-env NODE_ENV=production electron .",
    "app:dev": "concurrently -k --success first \"npm run dev -- --port 5180\" \"wait-on http://localhost:5180 && npm run electron:dev\"",
    "app:build": "npm run build && npm run build:electron && electron-builder --config.directories.output=release-build",
    "watch": "tsc -p electron/tsconfig.json --watch",
    "start": "npm run app:dev",
    "dist": "npm run build && npm run build:electron && copy electron\\wasapi-loopback.exe dist-electron\\wasapi-loopback.exe >nul 2>&1 & cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config.directories.output=release-build"
  },
  "build": {
    "appId": "com.insight.app",
    "productName": "Insight",
    "forceCodeSigning": false,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "electron/wasapi-loopback.exe",
        "to": "wasapi-loopback.exe"
      },
      { "from": ".env", "to": ".env" }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "C:\\Users\\Qaish\\Insight\\assets\\icons\\mac\\icon.icns",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist"
    },
    "win": {
      "artifactName": "Insight-Setup.${ext}",
      "executableName": "Insight",
      "icon": "C:\\Users\\Qaish\\Insight\\assets\\icons\\win\\icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": true,
      "sign": null
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/png/",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Insight",
      "uninstallDisplayName": "Insight"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Insight",
  "devDependencies": {
    "@types/node": "^22.19.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/screenshot-desktop": "^1.12.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.35.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@google/genai": "^0.12.0",
    "dotenv": "^17.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.33.5",
    "ws": "^8.19.0"
  }
}
